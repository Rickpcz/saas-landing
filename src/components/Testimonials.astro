---
const testimonials = [
  {
    quote: "StreamLine cut our project delivery time in half. The automation features alone saved us 10+ hours a week.",
    name: "Sarah Chen",
    role: "Head of Product",
    company: "Notion",
    initials: "SC",
    accent: "#6366f1",
  },
  {
    quote: "Finally a tool that doesn't get in the way. The UI is so clean and the integrations just work out of the box.",
    name: "Marcus Rivera",
    role: "Engineering Lead",
    company: "Linear",
    initials: "MR",
    accent: "#8b5cf6",
  },
  {
    quote: "We onboarded our entire team in a single afternoon. The learning curve is basically zero.",
    name: "Priya Patel",
    role: "Operations Manager",
    company: "Vercel",
    initials: "PP",
    accent: "#a78bfa",
  },
  {
    quote: "The analytics dashboard gives us insights we never had before. It's changed how we make decisions.",
    name: "James Okafor",
    role: "CEO",
    company: "Loom",
    initials: "JO",
    accent: "#6366f1",
  },
  {
    quote: "Best investment we made this year. ROI was visible within the first two weeks of using it.",
    name: "Emily Nakamura",
    role: "VP of Engineering",
    company: "Figma",
    initials: "EN",
    accent: "#8b5cf6",
  },
];
---

<section
  id="testimonials"
  style="
    background: #f5f0ff;
    padding: 120px 24px;
    position: relative;
    overflow: hidden;
  "
>
  <!-- Glow fondo -->
  <div style="
    position: absolute;
    top: -100px;
    left: 50%;
    transform: translateX(-50%);
    width: 700px;
    height: 500px;
    background: radial-gradient(ellipse, rgba(99,102,241,0.12) 0%, transparent 65%);
    pointer-events: none;
  "></div>

  <!-- Header -->
  <div class="testimonials-header" style="
    max-width: 600px;
    margin: 0 auto 56px;
    text-align: center;
    position: relative;
    z-index: 1;
  ">
    <div style="
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(99,102,241,0.1);
      border: 1px solid rgba(99,102,241,0.25);
      border-radius: 100px;
      padding: 6px 16px;
      margin-bottom: 20px;
    ">
      <span style="font-size: 13px; font-weight: 500; color: #6366f1;">What teams are saying</span>
    </div>
    <h2 style="
      font-family: 'Sora', sans-serif;
      font-size: clamp(32px, 4vw, 52px);
      font-weight: 800;
      letter-spacing: -1.5px;
      color: #0F0F0F;
      line-height: 1.1;
      margin-bottom: 16px;
    ">
      Loved by teams<br/>
      <span style="background: linear-gradient(135deg, #6366f1, #8b5cf6, #a78bfa); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">all over the world</span>
    </h2>
    <p style="font-size: 17px; color: #666; line-height: 1.7;">
      Join thousands of teams that already streamlined their workflow.
    </p>
  </div>

  <!-- Slider wrapper -->
  <div style="position: relative; max-width: 1100px; margin: 0 auto; z-index: 1;">
    <div id="slider-track" style="
      display: flex;
      gap: 20px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      padding: 12px 4px 20px;
      cursor: grab;
      -webkit-overflow-scrolling: touch;
    ">
      {testimonials.map((t) => (
        <div class="testimonial-card" style={`
          flex-shrink: 0;
          width: 300px;
          scroll-snap-align: start;
          background: rgba(255,255,255,0.75);
          backdrop-filter: blur(12px);
          -webkit-backdrop-filter: blur(12px);
          border: 1px solid rgba(255,255,255,0.9);
          border-radius: 20px;
          padding: 28px;
          box-shadow: 0 4px 24px rgba(99,102,241,0.06);
          position: relative;
          overflow: hidden;
          transition: box-shadow 0.3s, border-color 0.3s;
        `}>
          <!-- Glow corner -->
          <div style={`
            position: absolute;
            top: -30px; right: -30px;
            width: 100px; height: 100px;
            border-radius: 50%;
            background: radial-gradient(circle, ${t.accent}18 0%, transparent 70%);
            pointer-events: none;
          `}></div>

          <!-- Stars -->
          <div style="display: flex; gap: 3px; margin-bottom: 16px;">
            {Array.from({length: 5}).map(() => (
              <svg width="14" height="14" viewBox="0 0 16 16" fill="#f59e0b">
                <path d="M8 1l1.9 3.8 4.2.6-3 3 .7 4.2L8 10.5l-3.8 2 .7-4.2-3-3 4.2-.6z"/>
              </svg>
            ))}
          </div>

          <!-- Quote -->
          <p style="
            font-size: 14px;
            color: #444;
            line-height: 1.75;
            margin-bottom: 24px;
            font-style: italic;
          ">
            "{t.quote}"
          </p>

          <!-- Author -->
          <div style="display: flex; align-items: center; gap: 10px;">
            <div style={`
              width: 38px;
              height: 38px;
              border-radius: 50%;
              background: linear-gradient(135deg, ${t.accent}, ${t.accent}88);
              display: flex;
              align-items: center;
              justify-content: center;
              font-size: 12px;
              font-weight: 700;
              color: white;
              flex-shrink: 0;
            `}>
              {t.initials}
            </div>
            <div>
              <div style="font-size: 13px; font-weight: 600; color: #0F0F0F;">{t.name}</div>
              <div style="font-size: 11px; color: #888;">{t.role} · {t.company}</div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Fade edges -->
    <div style="position:absolute;top:0;left:0;width:40px;height:100%;background:linear-gradient(to right,#f5f0ff,transparent);pointer-events:none;z-index:2;"></div>
    <div style="position:absolute;top:0;right:0;width:40px;height:100%;background:linear-gradient(to left,#f5f0ff,transparent);pointer-events:none;z-index:2;"></div>
  </div>

  <!-- Navegación solo flechas -->
  <div style="
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-top: 32px;
    position: relative;
    z-index: 1;
  ">
    <button id="btn-prev" style="
      width: 44px; height: 44px;
      border-radius: 50%;
      border: 1.5px solid rgba(99,102,241,0.3);
      background: rgba(255,255,255,0.8);
      cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      transition: all 0.2s;
    ">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
        <path d="M10 12L6 8l4-4" stroke="#6366f1" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <button id="btn-next" style="
      width: 44px; height: 44px;
      border-radius: 50%;
      border: 1.5px solid rgba(99,102,241,0.3);
      background: rgba(255,255,255,0.8);
      cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      transition: all 0.2s;
    ">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
        <path d="M6 4l4 4-4 4" stroke="#6366f1" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>
</section>

<style>
  #slider-track::-webkit-scrollbar { display: none; }
  #slider-track:active { cursor: grabbing; }

  .testimonial-card:hover {
    box-shadow: 0 8px 32px rgba(99,102,241,0.18) !important;
    border-color: rgba(99,102,241,0.25) !important;
  }

  #btn-prev:hover, #btn-next:hover {
    background: #6366f1 !important;
    border-color: #6366f1 !important;
  }

  #btn-prev:hover svg path,
  #btn-next:hover svg path {
    stroke: white;
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  gsap.from(".testimonials-header", {
    opacity: 0, y: 40, duration: 0.8, ease: "power3.out",
    scrollTrigger: { trigger: ".testimonials-header", start: "top 85%" }
  });

  const CARD_WIDTH = 320;
  const TOTAL = 5;
  const track = document.getElementById("slider-track") as HTMLElement;

  // Clonar cards
  const originals = Array.from(track.children) as HTMLElement[];
  originals.forEach(c => track.appendChild(c.cloneNode(true)));
  originals.forEach(c => track.insertBefore(c.cloneNode(true), track.firstChild));

  // Apagar scroll nativo, controlar con transform
  track.style.overflow = "visible";
  track.style.display = "flex";
  track.style.gap = "20px";
  track.style.willChange = "transform";

  // Wrapper con overflow hidden
  const wrapper = track.parentElement as HTMLElement;
  wrapper.style.overflow = "hidden";

  let offset = -(TOTAL * CARD_WIDTH);
  let current = TOTAL;
  let isAnimating = false;

  gsap.set(track, { x: offset });

  // Animación entrada cards
  gsap.from(track.children, {
    opacity: 0, y: 40, duration: 0.6, ease: "power3.out", stagger: 0.08,
    scrollTrigger: { trigger: wrapper, start: "top 85%" }
  });

  function goTo(dir: number) {
    if (isAnimating) return;
    isAnimating = true;
    current += dir;
    offset = -(current * CARD_WIDTH);

    gsap.to(track, {
      x: offset,
      duration: 0.55,
      ease: "power2.inOut",
      onComplete: () => {
        // Loop infinito
        if (current >= TOTAL * 2) {
          current -= TOTAL;
          offset = -(current * CARD_WIDTH);
          gsap.set(track, { x: offset });
        } else if (current < TOTAL) {
          current += TOTAL;
          offset = -(current * CARD_WIDTH);
          gsap.set(track, { x: offset });
        }
        isAnimating = false;
      }
    });
  }

  document.getElementById("btn-prev")?.addEventListener("click", () => goTo(-1));
  document.getElementById("btn-next")?.addEventListener("click", () => goTo(1));

  // Drag
  let isDragging = false;
  let startX = 0;
  let startOffset = 0;

  track.addEventListener("mousedown", (e) => {
    if (isAnimating) return;
    isDragging = true;
    startX = e.clientX;
    startOffset = offset;
    track.style.cursor = "grabbing";
    gsap.killTweensOf(track);
  });

  window.addEventListener("mouseup", (e) => {
    if (!isDragging) return;
    isDragging = false;
    track.style.cursor = "grab";
    const diff = startX - e.clientX;
    if (Math.abs(diff) > 80) {
      goTo(diff > 0 ? 1 : -1);
    } else {
      // Snap de vuelta
      gsap.to(track, { x: offset, duration: 0.3, ease: "power2.out" });
    }
  });

  window.addEventListener("mousemove", (e) => {
    if (!isDragging) return;
    const newX = startOffset - (startX - e.clientX);
    gsap.set(track, { x: newX });
  });

  // Touch
  let touchStartX = 0;
  track.addEventListener("touchstart", (e) => {
    touchStartX = e.touches[0].clientX;
    startOffset = offset;
    gsap.killTweensOf(track);
  }, { passive: true });

  track.addEventListener("touchmove", (e) => {
    const newX = startOffset - (touchStartX - e.touches[0].clientX);
    gsap.set(track, { x: newX });
  }, { passive: true });

  track.addEventListener("touchend", (e) => {
    const diff = touchStartX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 50) {
      goTo(diff > 0 ? 1 : -1);
    } else {
      gsap.to(track, { x: offset, duration: 0.3, ease: "power2.out" });
    }
  });
</script>