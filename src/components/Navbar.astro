---
const links = [
  { label: "Features", href: "#features" },
  { label: "Testimonials", href: "#testimonials" },
  { label: "Pricing", href: "#pricing" },
];
---

<header
  id="navbar"
  style="
    position: fixed;
    top: 24px;
    left: 0;
    right: 0;
    z-index: 50;
    padding: 0 24px;
  "
>
  <nav
    style="
      max-width: 1024px;
      margin: 0 auto;
      border-radius: 16px;
      padding: 14px 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: rgba(255, 255, 255, 0.82);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      border: 1px solid rgba(255, 255, 255, 0.95);
      box-shadow: 0 4px 32px rgba(0, 0, 0, 0.07);
    "
  >
    <!-- Logo -->
    <a href="/" style="display: flex; align-items: center; gap: 10px; text-decoration: none; flex-shrink: 0;">
      <svg width="32" height="32" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect width="28" height="28" rx="8" fill="#6366f1"/>
        <path d="M8 14L12 18L20 10" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span style="font-size: 16px; font-weight: 700; letter-spacing: -0.3px; color: #0F0F0F; font-family: 'Sora', sans-serif;">
        Stream<span style="background: linear-gradient(135deg, #6366f1, #8b5cf6, #a78bfa); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">Line</span>
      </span>
    </a>

    <!-- Links desktop -->
    <ul id="nav-links" style="display: flex; align-items: center; gap: 32px; list-style: none; margin: 0; padding: 0;">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            style="font-size: 14px; font-weight: 500; color: #666; text-decoration: none; transition: color 0.2s;"
            onmouseover="this.style.color='#0F0F0F'"
            onmouseout="this.style.color='#666'"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- CTA desktop -->
    <div id="nav-cta" style="display: flex; align-items: center; gap: 16px;">
      <a
        href="#"
        style="font-size: 14px; font-weight: 500; color: #666; text-decoration: none; transition: color 0.2s;"
        onmouseover="this.style.color='#0F0F0F'"
        onmouseout="this.style.color='#666'"
      >
        Log in
      </a>
      <a
        href="#"
        style="
          font-size: 14px;
          font-weight: 600;
          color: #ffffff;
          background-color: #6366f1;
          padding: 10px 20px;
          border-radius: 10px;
          text-decoration: none;
          white-space: nowrap;
          transition: background-color 0.2s;
        "
        onmouseover="this.style.backgroundColor='#4f46e5'"
        onmouseout="this.style.backgroundColor='#6366f1'"
      >
        Get started
      </a>
    </div>

    <!-- Hamburger mobile -->
    <button
      id="menu-btn"
      style="display: none; flex-direction: column; gap: 5px; padding: 6px; background: none; border: none; cursor: pointer;"
      aria-label="Menu"
    >
      <span id="bar1" style="display: block; width: 22px; height: 2px; background-color: #0F0F0F; border-radius: 4px;"></span>
      <span id="bar2" style="display: block; width: 22px; height: 2px; background-color: #0F0F0F; border-radius: 4px;"></span>
      <span id="bar3" style="display: block; width: 22px; height: 2px; background-color: #0F0F0F; border-radius: 4px;"></span>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    style="
      display: none;
      margin-top: 8px;
      border-radius: 16px;
      background: rgba(255, 255, 255, 0.97);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      border: 1px solid rgba(255, 255, 255, 0.95);
      box-shadow: 0 8px 40px rgba(0, 0, 0, 0.1);
      overflow: hidden;
    "
  >
    <div style="display: flex; flex-direction: column; padding: 8px;">
      {links.map((link) => (
        <a
          href={link.href}
          style="
            font-size: 14px;
            font-weight: 500;
            color: #444;
            text-decoration: none;
            padding: 12px 16px;
            border-radius: 10px;
            transition: background 0.15s;
          "
          onmouseover="this.style.background='rgba(99,102,241,0.06)'; this.style.color='#6366f1'"
          onmouseout="this.style.background='transparent'; this.style.color='#444'"
        >
          {link.label}
        </a>
      ))}
      <div style="height: 1px; background: #f0f0f0; margin: 8px 0;"></div>
      <a
        href="#"
        style="
          font-size: 14px;
          font-weight: 500;
          color: #444;
          text-decoration: none;
          padding: 12px 16px;
          border-radius: 10px;
          transition: background 0.15s;
        "
        onmouseover="this.style.background='rgba(0,0,0,0.04)'"
        onmouseout="this.style.background='transparent'"
      >
        Log in
      </a>
      <a
        href="#"
        style="
          font-size: 14px;
          font-weight: 600;
          color: #ffffff;
          background: #6366f1;
          padding: 13px 16px;
          border-radius: 10px;
          text-align: center;
          text-decoration: none;
          margin-top: 4px;
          margin-bottom: 4px;
        "
      >
        Get started
      </a>
    </div>
  </div>
</header>

<script>
  import { gsap } from "gsap";

  const navbar = document.getElementById("navbar") as HTMLElement;

  // Entrada inicial — parte desde arriba pero ya en su posición top:24px
  gsap.set(navbar, { opacity: 0, y: -80 });
  gsap.to(navbar, {
    y: 0,
    opacity: 1,
    duration: 0.9,
    ease: "power3.out",
    delay: 0.2,
  });

  // Hide on scroll down / show on scroll up
  let lastScroll = 0;
  let hidden = false;

  window.addEventListener("scroll", () => {
    const current = window.scrollY;
    const delta = current - lastScroll;
    const heroHeight = window.innerHeight;

    if (current < heroHeight) {
      if (hidden) {
        gsap.to(navbar, { y: 0, opacity: 1, duration: 0.45, ease: "power3.out" });
        hidden = false;
      }
    } else if (delta > 6 && !hidden) {
      gsap.to(navbar, { y: -120, opacity: 0, duration: 0.35, ease: "power2.in" });
      hidden = true;
      if (open) {
        open = false;
        mobileMenu.style.display = "none";
      }
    } else if (delta < -6 && hidden) {
      gsap.to(navbar, { y: 0, opacity: 1, duration: 0.45, ease: "power3.out" });
      hidden = false;
    }

    lastScroll = current;
  }, { passive: true });

  // Responsive
  const navLinks = document.getElementById("nav-links");
  const navCta = document.getElementById("nav-cta") as HTMLElement;
  const menuBtn = document.getElementById("menu-btn") as HTMLElement;
  const mobileMenu = document.getElementById("mobile-menu") as HTMLElement;

  function handleResize() {
    if (window.innerWidth < 768) {
      navLinks!.style.display = "none";
      navCta!.style.display = "none";
      menuBtn!.style.display = "flex";
    } else {
      navLinks!.style.display = "flex";
      navCta!.style.display = "flex";
      menuBtn!.style.display = "none";
      mobileMenu.style.display = "none";
    }
  }

  handleResize();
  window.addEventListener("resize", handleResize);

  // Hamburger toggle
  let open = false;

  menuBtn?.addEventListener("click", () => {
    open = !open;

    if (open) {
      mobileMenu.style.display = "block";
      gsap.from(mobileMenu, { opacity: 0, y: -8, duration: 0.25, ease: "power2.out" });
    } else {
      gsap.to(mobileMenu, {
        opacity: 0, y: -8, duration: 0.2, ease: "power2.in",
        onComplete: () => {
          mobileMenu.style.display = "none";
          gsap.set(mobileMenu, { opacity: 1, y: 0 });
        }
      });
    }

    const bar1 = document.getElementById("bar1");
    const bar2 = document.getElementById("bar2");
    const bar3 = document.getElementById("bar3");

    if (open) {
      gsap.to(bar1, { rotate: 45, y: 7, duration: 0.3 });
      gsap.to(bar2, { opacity: 0, duration: 0.2 });
      gsap.to(bar3, { rotate: -45, y: -7, duration: 0.3 });
    } else {
      gsap.to(bar1, { rotate: 0, y: 0, duration: 0.3 });
      gsap.to(bar2, { opacity: 1, duration: 0.2 });
      gsap.to(bar3, { rotate: 0, y: 0, duration: 0.3 });
    }
  });

  mobileMenu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      open = false;
      gsap.to(mobileMenu, {
        opacity: 0, y: -8, duration: 0.2, ease: "power2.in",
        onComplete: () => {
          mobileMenu.style.display = "none";
          gsap.set(mobileMenu, { opacity: 1, y: 0 });
        }
      });
      gsap.to(document.getElementById("bar1"), { rotate: 0, y: 0, duration: 0.3 });
      gsap.to(document.getElementById("bar2"), { opacity: 1, duration: 0.2 });
      gsap.to(document.getElementById("bar3"), { rotate: 0, y: 0, duration: 0.3 });
    });
  });
</script>